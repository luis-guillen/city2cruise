{
  "title": "City2Cruise — RL Model (MLOps)",
  "uid": "city2cruise-rl-model",
  "schemaVersion": 39,
  "tags": ["city2cruise", "mlops", "rl"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latencia de inferencia p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rl_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Predicciones por segundo (por outcome)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(rl_predictions_total[1m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Mediana del score top-1 (drift de predicción)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(rl_ranking_top_score_bucket[5m])))",
          "legendFormat": "mediana score"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Modelo cargado — timesteps entrenados",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rl_model_total_timesteps", "legendFormat": "timesteps" }
      ]
    }
  ]
}
