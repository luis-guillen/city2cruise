# ─────────────────────────────────────────────────────────────────────────────
# STAGING (Fly.io + Neon + Upstash + Cloudflare Pages)
# Los valores reales se inyectan vía Fly secrets / GitHub Encrypted Secrets,
# este archivo sólo lista las variables que CADA entorno DEBE tener.
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=staging

# Backend (Fly.io app: city2cruise-staging-backend)
PORT=9000
# Pegar el output `terraform output -raw database_url` (rama "staging" de Neon)
DATABASE_URL=postgres://USER:PWD@HOST.neon.tech/city2cruise?sslmode=require
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379
JWT_SECRET=<openssl rand -hex 32>
REFRESH_TOKEN_SECRET=<openssl rand -hex 32>
AUDIT_HMAC_SECRET=<openssl rand -hex 32>
FIELD_ENCRYPTION_KEY=<openssl rand -hex 16>     # 32 bytes hex = 16 raw
FRONTEND_URL=https://city2cruise-staging-web.pages.dev
LOG_LEVEL=debug

# Stripe — TEST MODE en staging
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (Hito 5.3.1)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=staging

# Frontend (Cloudflare Pages env: city2cruise-staging-web)
VITE_API_URL=https://city2cruise-staging-backend.fly.dev/api
VITE_SOCKET_URL=https://city2cruise-staging-backend.fly.dev
VITE_ENV=staging
VITE_SENTRY_DSN=https://...@sentry.io/...

# Hito 5.4.4 — Torre de Control consume estado del Digital Twin
VITE_TWIN_URL=https://city2cruise-twin.fly.dev

# IA / RL
RL_SERVICE_URL=https://city2cruise-rl.fly.dev
TWIN_URL=https://city2cruise-twin.fly.dev
TWIN_PROVIDER=internal
MIROFISH_BASE_URL=
MIROFISH_API_KEY=
MIROFISH_PROJECT_ID=
MIROFISH_GRAPH_ID=
