# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (Fly.io + Neon + Upstash + Cloudflare Pages)
# Acceso restringido. Cualquier cambio debe pasar por PR + revisión.
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Backend (Fly.io app: city2cruise-production-backend)
PORT=9000
# Output `terraform output -raw database_url` con --workspace=production
DATABASE_URL=postgres://USER:PWD@HOST.neon.tech/city2cruise?sslmode=require
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379
JWT_SECRET=<openssl rand -hex 32>     # ROTAR CADA 90 DÍAS — Hito 5.2.5
REFRESH_TOKEN_SECRET=<openssl rand -hex 32>
AUDIT_HMAC_SECRET=<openssl rand -hex 32>
FIELD_ENCRYPTION_KEY=<openssl rand -hex 16>

# Custody ledger validators (3 procesos Node independientes con su propio volumen)
# En Docker Compose estos son los nombres de servicio: ledger-a, ledger-b, ledger-c
VALIDATOR_INTERNAL_KEY=<openssl rand -hex 32>
VALIDATOR_LEDGER_A_URL=http://ledger-a:4001
VALIDATOR_LEDGER_B_URL=http://ledger-b:4001
VALIDATOR_LEDGER_C_URL=http://ledger-c:4001
FRONTEND_URL=https://city2cruise.pages.dev
LOG_LEVEL=info

# Stripe — LIVE MODE en producción
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENTS_DEMO_MODE=false

# Sentry
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1   # 10% en prod por coste

# Frontend (Cloudflare Pages env: city2cruise-production-web)
VITE_API_URL=https://city2cruise-production-backend.fly.dev/api
VITE_SOCKET_URL=https://city2cruise-production-backend.fly.dev
VITE_ENV=production
VITE_SENTRY_DSN=https://...@sentry.io/...

# Hito 5.4.4 — Torre de Control consume estado del Digital Twin
VITE_TWIN_URL=https://city2cruise-twin.fly.dev

# IA / RL
RL_REBALANCE_ACTIVE=false
RL_SERVICE_URL=https://city2cruise-rl.fly.dev
TWIN_URL=https://city2cruise-twin.fly.dev
TWIN_PROVIDER=internal
MIROFISH_BASE_URL=
MIROFISH_API_KEY=
MIROFISH_PROJECT_ID=
MIROFISH_GRAPH_ID=
