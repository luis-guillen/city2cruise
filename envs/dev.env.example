# ─────────────────────────────────────────────────────────────────────────────
# DEV (local docker-compose)
# Carga: `direnv allow` o `set -a; source envs/dev.env; set +a; docker compose up`
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# Backend
PORT=9000
DATABASE_URL=postgres://cruise:cruise_secret@db:5432/cruise_connect
REDIS_URL=redis://redis:6379
JWT_SECRET=dev_jwt_secret_change_for_local_only_32bytes_min!
REFRESH_TOKEN_SECRET=dev_refresh_secret_change_for_local_only_32bytes!
AUDIT_HMAC_SECRET=dev_audit_hmac_secret_change_for_local_only_32!
FIELD_ENCRYPTION_KEY=dev_field_enc_key_32bytes_change!!
FRONTEND_URL=http://localhost:9100
LOG_LEVEL=debug

# Frontend (Vite)
VITE_API_URL=http://localhost:9000/api
VITE_SOCKET_URL=http://localhost:9000
VITE_ENV=development
VITE_DEMO_MODE=true

# AI / RL
RL_SERVICE_URL=http://rl_service:8080
TWIN_URL=http://digital_twin:8090
TWIN_PROVIDER=internal
PAYMENTS_DEMO_MODE=true
MIROFISH_BASE_URL=
MIROFISH_API_KEY=
MIROFISH_PROJECT_ID=
MIROFISH_GRAPH_ID=
