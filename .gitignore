node_modules/
.DS_Store
.env
.idea/
.vscode/
*.log

# Hito 5.2.3 — env files reales nunca al repo (sólo *.example)
envs/*.env
!envs/*.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.venv/
.claude/
# Playwright (Hito 6.2)
cruise-connect-main/e2e/.results/
cruise-connect-main/e2e/.report/
cruise-connect-main/test-results/
cruise-connect-main/playwright-report/

# Hito 6 — coverage artifacts
cruise-connect-main/coverage/
backend/coverage/
.coverage
htmlcov/

# RL training run outputs — keep only the evidence referenced by the memoria,
# ignore regenerable logs/checkpoints (regenerate: python -m rl_service.train_tfm)
rl_service/artifacts/*
!rl_service/artifacts/cruise_dispatch_ppo.zip
!rl_service/artifacts/cruise_dispatch_ppo.meta.json
!rl_service/artifacts/cruise_dispatch_ppo_benchmark_v3.zip
!rl_service/artifacts/rewards.csv
!rl_service/artifacts/benchmark.json
!rl_service/artifacts/fidelity.json
!rl_service/artifacts/summary.json
!rl_service/artifacts/drift_baseline.json

# TensorBoard logs & TS incremental build cache
**/tb/
*.tfevents.*
*.tsbuildinfo

# MLflow local experiment store
mlruns/

# Model registry: track the index + cards + metadata, ignore the model blobs
rl_service/registry/**/model.zip

